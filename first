local SUPERJUMP_POWER = 400
local SPIN_SPEED = 5

local modified = {}
local boxes = {}

--==================================================
-- HITBOX LOGIC
--==================================================
local function createVisualHead(realHead)
    local clone = realHead:Clone()
    clone.Name = "VisualHead"
    clone.Size = Vector3.new(2,1,1)
    clone.Transparency = 0
    clone.CanCollide = false
    clone.Massless = true
    clone.Parent = realHead.Parent
    local weld = Instance.new("WeldConstraint")
    weld.Part0 = realHead
    weld.Part1 = clone
    weld.Parent = clone
    return clone
end

local function applyHitbox(character)
    if modified[character] then return end
    local head = character:FindFirstChild("Head")
    if not head then return end
    modified[character] = {Size=head.Size, Transparency=head.Transparency, Visual=nil}
    head.Size = Vector3.new(HITBOX_SIZE,HITBOX_SIZE,HITBOX_SIZE)
    head.Transparency = 1
    head.CanCollide = false
    head.Massless = true
    modified[character].Visual = createVisualHead(head)
end

local function restoreHitbox(character)
    local data = modified[character]
    if not data then return end
    local head = character:FindFirstChild("Head")
    if head then
        head.Size = data.Size
        head.Transparency = data.Transparency
    end
    if data.Visual then data.Visual:Destroy() end
    modified[character] = nil
end

local function refreshHitboxes()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            restoreHitbox(plr.Character)
            if ENABLED_HITBOX then applyHitbox(plr.Character) end
        end
    end
end

--==================================================
-- ESP LOGIC
--==================================================
local function createESP(char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local box = Instance.new("BoxHandleAdornment")
    box.Adornee = hrp
    box.AlwaysOnTop = true
    box.ZIndex = 10
    box.Size = Vector3.new(2,5,1)
    box.Color3 = ESP_COLOR
    box.Transparency = 0.5
    box.Parent = workspace
    boxes[char] = box
end

local function removeESP(char)
    if boxes[char] then boxes[char]:Destroy() boxes[char]=nil end
end

local function refreshESP()
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            removeESP(plr.Character)
            if ENABLED_ESP then createESP(plr.Character) end
        end
    end
end

--==================================================
-- SUPERJUMP LOGIC
--==================================================
local attacking = false
local hitEnemyRecently = false

local function getCharacter() return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait() end
local function isOnGround(humanoid) return humanoid.FloorMaterial ~= Enum.Material.Air end

local function monitorAttacks(humanoid)
    humanoid.AnimationPlayed:Connect(function(track)
        local name = string.lower(track.Name)
        if name:find("attack") or name:find("slash") or name:find("hit") then
            attacking = true
            hitEnemyRecently = false
            task.delay(0.4,function() attacking=false end)
        end
    end)
end

local function monitorHits(character)
    for _, part in pairs(character:GetChildren()) do
        if part:IsA("BasePart") then
            part.Touched:Connect(function(hit)
                local hum = hit.Parent and hit.Parent:FindFirstChild("Humanoid")
                if hum and hum.Parent ~= character then hitEnemyRecently=true end
            end)
        end
    end
end

local function setupCharacter(char)
    local humanoid = char:WaitForChild("Humanoid")
    monitorAttacks(humanoid)
    monitorHits(char)
end

LocalPlayer.CharacterAdded:Connect(setupCharacter)
if LocalPlayer.Character then setupCharacter(LocalPlayer.Character) end

local function doSuperJump()
    if not ENABLED_SUPERJUMP then return end
    local char = getCharacter()
    local humanoid = char:FindFirstChild("Humanoid")
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end
    if not isOnGround(humanoid) then return end
    if attacking and hitEnemyRecently then return end
    rootPart.Velocity = Vector3.new(0,SUPERJUMP_POWER,0)
end

UIS.InputBegan:Connect(function(input,gp)
    if gp then return end
    if input.KeyCode==Enum.KeyCode.Space then doSuperJump() end
end)
UIS.JumpRequest:Connect(doSuperJump)

--==================================================
-- SPIN LOGIC
--==================================================
RunService.RenderStepped:Connect(function()
    if ENABLED_SPIN then
        local char = getCharacter()
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(SPIN_SPEED), 0)
        end
    end
end)

