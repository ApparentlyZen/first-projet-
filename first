-- GRID TOGGLES
local toggleYStart=60
local toggleSpacingX=0.5
local toggleSpacingY=55

local function createToggleGrid(text,col,row,callback)
    local toggle=Instance.new("TextButton",card)
    toggle.Size=UDim2.new(0.48,-10,0,40)
    toggle.Position=UDim2.new(toggleSpacingX*(col-1),10,0,toggleYStart+toggleSpacingY*(row-1))
    toggle.BackgroundColor3=Color3.fromRGB(60,60,70)
    toggle.Text=text.." : OFF"
    toggle.Font=Enum.Font.Gotham
    toggle.TextSize=14
    toggle.TextColor3=Color3.fromRGB(240,240,240)
    Instance.new("UICorner",toggle).CornerRadius=UDim.new(0,10)
    local state=false
    toggle.MouseButton1Click:Connect(function()
        state=not state
        toggle.Text=text..(state and " : ON" or " : OFF")
        callback(state)
    end)
    return toggle
end

